{
  "manifest_version": 3,
  "name": "HiFlow",
  "version": "0.1.0",
  "description": "BOSS jobs matching floating panel backed by a localhost matcher.",
  "action": {
    "default_title": "Open HiFlow"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/web/geek/jobs*",
        "https://www.zhipin.com/web/geek/job*"
      ],
      "js": [
        "content/common.js",
        "content/jobs.js",
        "content/floating-panel.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.zhipin.com/web/geek/chat*"
      ],
      "js": [
        "content/common.js",
        "content/chat.js",
        "content/floating-panel.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.zhipin.com/web/geek/resume*"
      ],
      "js": [
        "content/resume.js",
        "content/floating-panel.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/floating-panel.css"
      ],
      "matches": [
        "https://www.zhipin.com/*"
      ]
    }
  ]
}
